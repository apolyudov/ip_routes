#!/usr/bin/env python3
"""Tests for ga_qr_decode.py (no network)."""

import subprocess
import sys
import unittest
from pathlib import Path

ROOT = Path(__file__).resolve().parent
DECODE = ROOT / "ga_qr_decode.py"


class TestGaQrDecode(unittest.TestCase):
    def run_decode(self, *args: str) -> str:
        r = subprocess.run(
            [sys.executable, str(DECODE), *args],
            capture_output=True,
            text=True,
            check=True,
        )
        return r.stdout

    def test_totp_uri(self):
        uri = "otpauth://totp/Test:user?secret=JBSWY3DPEHPK3PXP&issuer=Test"
        out = self.run_decode("--uri", uri)
        self.assertIn("JBSWY3DPEHPK3PXP", out)
        self.assertIn("Test", out)

    def test_totp_uri_json(self):
        uri = "otpauth://totp/Acme?secret=GEZDGNBVGY3TQOJQ&issuer=Acme"
        r = subprocess.run(
            [sys.executable, str(DECODE), "--uri", uri, "--json"],
            capture_output=True,
            text=True,
            check=True,
        )
        self.assertIn("GEZDGNBVGY3TQOJQ", r.stdout)


if __name__ == "__main__":
    unittest.main()
